{
  "style_preset_id": "salmon_direct_contrast_v1",
  "version": "1.0.0",
  "theme": "light_contrast",
  "palette": {
    "bg_base": "#FFFFFF",
    "surface": "#FFFFFF",
    "surface_soft": "#F8F6F3",
    "stroke": "#E3DFD9",
    "text_primary": "#141414",
    "text_secondary": "#555555",
    "text_muted": "#777777",
    "brand_coral": "#F45B5F",
    "chart_neutral": "#C9D0D7"
  },
  "fonts": {
    "heading": "Arial Rounded MT Bold",
    "body": "Arial",
    "sizes": {
      "h1": 54,
      "h2": 36,
      "h3": 26,
      "body": 18,
      "small": 14,
      "caption": 12
    }
  },
  "layout": {
    "slide_width": 13.333,
    "slide_height": 7.5,
    "margin_left": 0.84,
    "margin_right": 0.84,
    "margin_top": 0.64,
    "margin_bottom": 0.64,
    "grid_gap": 0.28,
    "section_gap": 0.44
  },
  "shape": {
    "card_radius": 0.14,
    "button_radius": 0.12,
    "stroke_width": 1,
    "icon_border_width": 1.2
  },
  "components": {
    "micro_label": {
      "position": "top_left",
      "font": "Arial Rounded MT Bold",
      "size": 11,
      "color": "#F45B5F",
      "char_spacing": 1.1
    },
    "headline": {
      "font": "Arial Rounded MT Bold",
      "size": 54,
      "color": "#141414",
      "line_spacing": 1.08
    },
    "subtitle": {
      "font": "Arial",
      "size": 18,
      "color": "#555555",
      "line_spacing": 1.15
    },
    "cta_primary": {
      "fill": "#FFFFFF",
      "stroke": "#F45B5F",
      "text_color": "#F45B5F",
      "font": "Arial Rounded MT Bold",
      "font_size": 12
    },
    "info_card": {
      "fill": "#FFFFFF",
      "stroke": "#E3DFD9",
      "title_color": "#F45B5F",
      "text_color": "#141414",
      "caption_color": "#555555"
    },
    "benefit_card": {
      "fill": "#FFFFFF",
      "stroke": "#E3DFD9",
      "title_color": "#141414",
      "text_color": "#555555",
      "icon_fill": "#FFFFFF",
      "icon_stroke": "#F45B5F",
      "icon_color": "#F45B5F"
    },
    "table": {
      "header_fill": "#FFFFFF",
      "header_text": "#141414",
      "row_fill": "#FFFFFF",
      "row_alt_fill": "#F8F6F3",
      "text": "#141414",
      "key_value": "#F45B5F",
      "border": "#E3DFD9"
    },
    "chart": {
      "primary": "#F45B5F",
      "secondary": "#C9D0D7",
      "axis": "#777777",
      "grid": "#E3DFD9"
    }
  },
  "slide_templates": {
    "title": {
      "composition": "headline_left_info_card_right",
      "required": ["micro_label", "headline", "subtitle", "info_card", "cta_primary"]
    },
    "content": {
      "composition": "headline_top_benefit_cards_grid",
      "required": ["micro_label", "headline", "benefit_card"]
    },
    "two_column": {
      "composition": "headline_top_two_equal_cards",
      "required": ["micro_label", "headline"]
    },
    "paragraph": {
      "composition": "headline_top_text_block",
      "required": ["micro_label", "headline"]
    },
    "table": {
      "composition": "headline_top_table_center",
      "required": ["micro_label", "headline", "table"]
    },
    "closing": {
      "composition": "single_statement_center",
      "required": ["micro_label", "headline"]
    }
  },
  "content_constraints": {
    "title_max_words": 8,
    "subtitle_max_words": 18,
    "bullet_max_items": 5,
    "bullet_max_words": 12,
    "table_max_columns": 5,
    "chart_max_categories": 6
  }
}
